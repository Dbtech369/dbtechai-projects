# --- Mailbox being watched (the throwaway/demo address for THIS target) ---
IMAP_HOST=imap.gmail.com
EMAIL_ADDRESS=demo@yourdomain.com
EMAIL_APP_PASSWORD=your-app-password-here
DRAFTS_FOLDER=[Gmail]/Drafts

# --- LLM backend ---
# "gemini" = direct Gemini API call
# "hermes" = route through your local Hermes agent endpoint
LLM_PROVIDER=gemini

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

HERMES_API_URL=http://localhost:8000
